<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Albasse Shopping</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Poppins',sans-serif}
body{background:#f5f5f5}
header{background:#111;color:#fff;padding:15px 30px;display:flex;justify-content:space-between;align-items:center}
header h1{color:#f9b233}
nav a{color:#fff;margin:0 10px;text-decoration:none}
.cart,.account{background:#f9b233;padding:8px 15px;border-radius:10px;cursor:pointer;color:black;font-weight:bold;margin-left:10px}
.hero{height:60vh;background:url('https://images.unsplash.com/photo-1521336575822-6da63fb45455') center/cover;display:flex;align-items:center;justify-content:center;color:white;text-align:center}
.hero h2{font-size:40px;background:rgba(0,0,0,0.5);padding:20px}
.products{padding:40px;display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:20px}
.product{background:#fff;border-radius:15px;overflow:hidden;box-shadow:0 5px 15px rgba(0,0,0,0.1);transition:.3s}
.product:hover{transform:translateY(-5px)}
.product img{width:100%;height:250px;object-fit:cover}
.product-content{padding:15px}
.price{color:#f9b233;font-weight:bold}
.btn{display:block;margin-top:10px;padding:10px;background:#111;color:white;text-align:center;border-radius:10px;cursor:pointer}
.whatsapp{position:fixed;bottom:20px;right:20px;background:#25D366;color:white;padding:15px;border-radius:50%;font-size:20px}
.modal{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);display:none;align-items:center;justify-content:center}
.modal-content{background:white;padding:20px;border-radius:15px;width:300px}
.modal input,select{width:100%;padding:10px;margin:5px 0}
footer{background:#111;color:white;text-align:center;padding:20px;margin-top:40px}
</style>
</head>
<body>

<header>
<h1>Albasse Shopping</h1>
<nav>
<a href="#">Accueil</a>
<a href="#">Produits</a>
</nav>
<div style="display:flex;align-items:center;">
<div class="account" onclick="openAuth()">👤 Compte</div>
<div class="cart" onclick="showCart()">🛒 (<span id="cart-count">0</span>)</div>
</div>
</header>

<section class="hero">
<h2>Style & Élégance au Tchad</h2>
</section>

<section class="products">

<div class="product">
<img src="https://images.unsplash.com/photo-1526178613552-2b45c6c302f0">
<div class="product-content">
<h3>Parfum Homme Premium</h3>
<p class="price">25 000 FCFA</p>
<div class="btn" onclick="addToCart('Parfum',25000)">Ajouter</div>
</div>
</div>

<div class="product">
<img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff">
<div class="product-content">
<h3>Chaussure Luxe</h3>
<p class="price">40 000 FCFA</p>
<div class="btn" onclick="addToCart('Chaussure',40000)">Ajouter</div>
</div>
</div>

</section>

<!-- AUTH -->
<div class="modal" id="authModal">
<div class="modal-content">
<h3>Compte</h3>
<input type="text" id="name" placeholder="Nom">
<input type="email" id="email" placeholder="Email">
<input type="password" id="password" placeholder="Mot de passe">
<div class="btn" onclick="register()">S'inscrire</div>
<div class="btn" onclick="login()">Se connecter</div>
</div>
</div>

<!-- CHECKOUT -->
<div class="modal" id="checkoutModal">
<div class="modal-content">
<h3>Livraison & Paiement</h3>
<input type="text" id="address" placeholder="Quartier (N'Djamena)">
<select id="payment">
<option value="Airtel Money">Airtel Money</option>
<option value="Moov Money">Moov Money</option>
</select>
<div class="btn" onclick="confirmOrder()">Confirmer</div>
</div>
</div>

<!-- ADMIN -->
<div class="modal" id="adminModal">
<div class="modal-content">
<h3>Admin - Ajouter produit</h3>
<input type="text" id="pname" placeholder="Nom produit">
<input type="number" id="pprice" placeholder="Prix">
<input type="text" id="pimage" placeholder="URL image">
<div class="btn" onclick="addProduct()">Ajouter produit</div>
</div>
</div>

<div class="whatsapp" onclick="openCheckout()">💳</div>

<button onclick="openAdmin()" style="position:fixed;bottom:20px;left:20px;padding:10px;border:none;background:black;color:white;border-radius:10px;">ADMIN</button>

<footer>
<p>Contact: 60 60 51 51 | N'Djamena</p>
</footer>

<script>
let cart=[];let user=null;

// PANIER
function addToCart(n,p){
if(!user){alert('Connectez-vous');return;}
cart.push({n,p});
document.getElementById('cart-count').innerText=cart.length;
}

function showCart(){
let m='Panier:\n';let t=0;
cart.forEach(i=>{m+=i.n+' - '+i.p+' FCFA\n';t+=i.p});
m+='Total: '+t+' FCFA';
alert(m);
}

// AUTH
function openAuth(){
document.getElementById('authModal').style.display='flex';
}

function register(){
let n=name.value,e=email.value,p=password.value;
localStorage.setItem('user',JSON.stringify({n,e,p}));
alert('Compte créé');
}

function login(){
let e=email.value,p=password.value;
let u=JSON.parse(localStorage.getItem('user'));
if(u&&u.e===e&&u.p===p){
user=u;
alert('Bienvenue '+u.n);
authModal.style.display='none';
}else alert('Erreur');
}

// CHECKOUT
function openCheckout(){
if(cart.length===0){alert('Panier vide');return;}
checkoutModal.style.display='flex';
}

function confirmOrder(){
let addr=document.getElementById('address').value;
let pay=document.getElementById('payment').value;
let text='Commande Albasse:%0A';
let total=0;

cart.forEach(i=>{
text+=i.n+' - '+i.p+' FCFA%0A';
total+=i.p;
});

text+='Total: '+total+' FCFA%0AAdresse: '+addr+'%0APaiement: '+pay;

window.open('https://wa.me/23560605151?text='+text,'_blank');
}

// ADMIN
let adminPassword = "admin123";

function openAdmin(){
let pass = prompt("Mot de passe admin");
if(pass===adminPassword){
adminModal.style.display='flex';
}else alert("Accès refusé");
}

function addProduct(){
let name=document.getElementById('pname').value;
let price=document.getElementById('pprice').value;
let image=document.getElementById('pimage').value;

let html=`
<div class="product">
<img src="${image}">
<div class="product-content">
<h3>${name}</h3>
<p class="price">${price} FCFA</p>
<div class="btn" onclick="addToCart('${name}',${price})">Ajouter</div>
</div>
</div>`;

document.querySelector('.products').innerHTML+=html;
alert('Produit ajouté');
}
</script>

</body>
</html>
